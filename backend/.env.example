# Only required for Cloud/Groq mode
GROQ_API_KEY=your_groq_api_key

# Optional overrides (defaults work for local dev)
# GROQ_MODEL=llama-3.1-8b-instant
# LLM_PROVIDER=groq
# OLLAMA_MODEL=llama3.1:8b
# OLLAMA_BASE_URL=http://localhost:11434

# Vision ingest (images in documents) — on by default
# ENABLE_VISION_INGEST=true
# VISION_PROVIDER=ollama
# OLLAMA_VISION_MODEL=llama3.2-vision
# GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Audit logging
# ENABLE_AUDIT_LOGGING=true
# ENABLE_AUDIT_API=false
# AUDIT_DB_PATH=./audit_logs.db

# Required in production
# CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000
